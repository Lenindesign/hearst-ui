{
  "name": "@hearst/ui",
  "version": "0.1.0",
  "description": "Hearst Design System — multi-brand component library powered by Token Studio tokens",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./globals.css": "./dist/globals.css",
    "./themes/*": "./dist/themes/*"
  },
  "bin": {
    "hearst-ui": "./cli/index.ts"
  },
  "files": [
    "dist",
    "src",
    "cli",
    "registry"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup && npm run build:css",
    "build:css": "node scripts/copy-css.js",
    "sync-tokens": "tsx scripts/sync-tokens.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build:site": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "vite": "^6"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leninaviles/hearst-ui"
  }
}
